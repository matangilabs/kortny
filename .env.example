# Required: Slack app credentials
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-socket-mode-token
SLACK_SIGNING_SECRET=your-signing-secret

# Required: initial LLM route
# After startup, admins can manage providers and tier routing from the dashboard.
LLM_PROVIDER=openrouter
LLM_API_KEY=your-provider-key
LLM_MODEL=openai/gpt-4o

# Required: Composio integration broker
# Used for the built-in integration catalog and connected-account tooling.
COMPOSIO_API_KEY=your-composio-api-key

# Required: dashboard Slack identity
# Add this exact redirect URL to your Slack app OAuth settings.
DASHBOARD_AUTH_MODE=hybrid
DASHBOARD_SLACK_CLIENT_ID=your-slack-client-id
DASHBOARD_SLACK_CLIENT_SECRET=your-slack-client-secret
DASHBOARD_SLACK_REDIRECT_URI=http://localhost:8080/auth/slack/callback

# Optional: Brave Search API key for search tool integration but you can also configure search through Composio
# BRAVE_SEARCH_API_KEY=

# Optional: dashboard/provider-admin hardening
# ENCRYPTION_KEY=change-me-long-random-secret
# DASHBOARD_USERNAME=kortny
# DASHBOARD_PASSWORD=change-me
# DASHBOARD_SESSION_SECRET=change-me-dashboard-session-secret
# DASHBOARD_HOST_PORT=8080

# Optional: LLM tier overrides
# LLM_CHEAP_MODEL=
# LLM_STANDARD_MODEL=
# LLM_ANALYSIS_MODEL=
# LLM_DOCUMENT_MODEL=
# LLM_HIGH_REASONING_MODEL=
# LLM_HUMANIZER_MODEL=

# Optional: runtime tuning
# AGENT_RUNTIME=adk
# KORTNY_WORKFLOW_BACKEND=temporal
# KORTNY_PLANNED_WORKFLOWS_ENABLED=true
# KORTNY_PLANNED_WORKFLOW_COST_CEILING_USD=0.75

# Optional: Scheduler and Witness tuning
# The Compose stack starts both by default. Witness creates dashboard candidates
# but does not send proactive DMs unless KORTNY_WITNESS_DELIVER_PRIVATE=true.
# KORTNY_SCHEDULER_POLL_INTERVAL_SECONDS=5
# KORTNY_WITNESS_ENABLED=true
# KORTNY_WITNESS_DELIVER_PRIVATE=false
# KORTNY_WITNESS_POLL_INTERVAL_SECONDS=300

# Optional: local ports and database credentials
# Compose injects POSTGRES_URL into containers automatically.
# POSTGRES_HOST_PORT=5432
# POSTGRES_DB=kortny
# POSTGRES_USER=kortny
# POSTGRES_PASSWORD=kortny
# POSTGRES_URL=postgresql://kortny:kortny@localhost:5432/kortny

# Optional: OTEL/Phoenix/Langfuse observability
# OBSERVABILITY_ENABLED=true
# OBSERVABILITY_CAPTURE_CONTENT=metadata
# OTEL_EXPORTER_OTLP_ENDPOINT=
# OTEL_EXPORTER_OTLP_HEADERS=
# LANGFUSE_ENABLED=false
# LANGFUSE_HOST=
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=

# Optional: local Phoenix profile
# PHOENIX_IMAGE=arizephoenix/phoenix:latest
# PHOENIX_HOST_PORT=6006
# PHOENIX_SQL_DATABASE_URL=

# Optional: local Temporal ports
# TEMPORAL_HOST_PORT=7233
# TEMPORAL_UI_HOST_PORT=8233
