# Slack app credentials
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-socket-mode-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_APP_NAME=kortny

# LLM provider routing
LLM_PROVIDER=openrouter
LLM_API_KEY=your-provider-key
LLM_MODEL=openai/gpt-4o
LLM_CHEAP_MODEL=
LLM_STANDARD_MODEL=
LLM_ANALYSIS_MODEL=
LLM_DOCUMENT_MODEL=
LLM_HIGH_REASONING_MODEL=

# External integrations
COMPOSIO_API_KEY=
BRAVE_SEARCH_API_KEY=

# Slack file reads
SLACK_FILE_READ_MAX_BYTES=26214400

# Persistence
POSTGRES_URL=postgresql://kortny:kortny@localhost:5432/kortny
POSTGRES_DB=kortny
POSTGRES_USER=kortny
POSTGRES_PASSWORD=kortny
POSTGRES_HOST_PORT=5432
