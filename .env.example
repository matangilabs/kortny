# Slack app credentials
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-socket-mode-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_APP_NAME=kortny

# LLM provider routing
LLM_PROVIDER=openrouter
LLM_API_KEY=your-provider-key
LLM_MODEL=openai/gpt-4o
LLM_CHEAP_MODEL=
LLM_STANDARD_MODEL=
LLM_ANALYSIS_MODEL=
LLM_DOCUMENT_MODEL=
LLM_HIGH_REASONING_MODEL=
LLM_HUMANIZER_MODEL=
# Required before saving dashboard-managed provider API keys.
ENCRYPTION_KEY=change-me-long-random-secret
RESPONSE_HUMANIZER_ENABLED=true
RESPONSE_HUMANIZER_MIN_CHARS=120
AGENT_RUNTIME=adk
# Planned workflow orchestration for complex multi-source tasks.
KORTNY_PLANNED_WORKFLOWS_ENABLED=true
KORTNY_PLANNED_WORKFLOW_MAX_PARALLEL_BRANCHES=3
KORTNY_PLANNED_WORKFLOW_COST_CEILING_USD=0.75
KORTNY_PLANNED_WORKFLOW_MAX_BRANCH_MODEL_CALLS=3
KORTNY_PLANNED_WORKFLOW_MAX_BRANCH_TOOL_CALLS=8
KORTNY_PLANNED_WORKFLOW_MAX_TOTAL_TOOL_CALLS=12
KORTNY_PLANNED_WORKFLOW_PROGRESS_UPDATES_ENABLED=true
# Durable workflow backend. Temporal is part of the default local stack.
KORTNY_WORKFLOW_BACKEND=temporal
TEMPORAL_ADDRESS=temporal:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=kortny-workflows

# Postgres-native scheduler. This materializes due schedules into normal tasks.
KORTNY_SCHEDULER_POLL_INTERVAL_SECONDS=5
KORTNY_SCHEDULER_MATERIALIZE_LIMIT=50
KORTNY_SCHEDULER_ADVISORY_LOCK_KEY=759340185

# External integrations
COMPOSIO_API_KEY=
COMPOSIO_CATALOG_ENABLED=true
COMPOSIO_CATALOG_LIMIT=60
COMPOSIO_REQUEST_TIMEOUT_SECONDS=10
TOOL_SELECTOR_MAX_PROMPT_CHARS=12000
BRAVE_SEARCH_API_KEY=

# Slack file reads
SLACK_FILE_READ_MAX_BYTES=26214400

# Read-only operator dashboard
DASHBOARD_AUTH_MODE=bootstrap
DASHBOARD_USERNAME=kortny
DASHBOARD_PASSWORD=change-me
DASHBOARD_SESSION_SECRET=change-me-dashboard-session-secret
DASHBOARD_SECURE_COOKIES=false
DASHBOARD_HOST_PORT=8080
# Optional Sign in with Slack for per-user dashboard identity.
# Use auth mode "hybrid" while bootstrapping, then "slack" when ready.
DASHBOARD_SLACK_CLIENT_ID=
DASHBOARD_SLACK_CLIENT_SECRET=
DASHBOARD_SLACK_REDIRECT_URI=http://localhost:8080/auth/slack/callback
DASHBOARD_SLACK_OAUTH_STATE_TTL_MINUTES=10

# Observability
OBSERVABILITY_ENABLED=true
OBSERVABILITY_CAPTURE_CONTENT=metadata
# Leave blank for local logs/task_events only. Use /v1/traces for OTLP HTTP.
# Phoenix local profile: http://phoenix:6006/v1/traces
# Langfuse Cloud: https://cloud.langfuse.com/api/public/otel/v1/traces
OTEL_EXPORTER_OTLP_ENDPOINT=
# Langfuse Cloud requires: Authorization=Basic <base64-public-secret>,x-langfuse-ingestion-version=4
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_SERVICE_NAME=kortny
OTEL_APP_SERVICE_NAME=kortny-app
OTEL_WORKER_SERVICE_NAME=kortny-worker
OTEL_SCHEDULER_SERVICE_NAME=kortny-scheduler
OTEL_TRACE_SAMPLING_RATIO=1.0

# Optional Langfuse Cloud observability and prompt management
LANGFUSE_ENABLED=false
LANGFUSE_HOST=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_PROMPTS_ENABLED=false
LANGFUSE_PROMPT_LABEL=production
KORTNY_RELEASE=
KORTNY_VERSION=

# Optional local Phoenix trace UI. Run with `make compose-up-observability`
# or `OTEL_EXPORTER_OTLP_ENDPOINT=http://phoenix:6006/v1/traces docker compose --profile observability up -d`.
PHOENIX_IMAGE=arizephoenix/phoenix:latest
PHOENIX_HOST_PORT=6006
PHOENIX_GRPC_HOST_PORT=4317
# Leave blank to use the Compose default SQLite database at /mnt/data/phoenix.db.
# Set to postgresql://user:password@host:5432/dbname for a production Phoenix DB.
PHOENIX_SQL_DATABASE_URL=
PHOENIX_DEFAULT_RETENTION_POLICY_DAYS=30
PHOENIX_TELEMETRY_ENABLED=false

# Local Temporal workflow backend. Included in the default Compose stack.
TEMPORAL_IMAGE=temporalio/temporal:latest
TEMPORAL_HOST_PORT=7233
TEMPORAL_UI_HOST_PORT=8233
OTEL_TEMPORAL_WORKER_SERVICE_NAME=kortny-temporal-worker

# Persistence
POSTGRES_URL=postgresql://kortny:kortny@localhost:5432/kortny
POSTGRES_DB=kortny
POSTGRES_USER=kortny
POSTGRES_PASSWORD=kortny
POSTGRES_HOST_PORT=5432
