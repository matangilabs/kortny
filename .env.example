# Required: Slack app credentials
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-socket-mode-token
SLACK_SIGNING_SECRET=your-signing-secret

# Required: initial LLM route
# After startup, admins can manage providers and tier routing from the dashboard.
LLM_PROVIDER=openrouter
LLM_API_KEY=your-provider-key
LLM_MODEL=openai/gpt-4o

# Required: Composio integration broker
# Used for the built-in integration catalog and connected-account tooling.
COMPOSIO_API_KEY=your-composio-api-key

# Required: dashboard Slack identity
# Add this exact redirect URL to your Slack app OAuth settings.
DASHBOARD_AUTH_MODE=hybrid
DASHBOARD_SLACK_CLIENT_ID=your-slack-client-id
DASHBOARD_SLACK_CLIENT_SECRET=your-slack-client-secret
DASHBOARD_SLACK_REDIRECT_URI=http://localhost:8080/auth/slack/callback

# Optional: Brave Search API key for search tool integration but you can also configure search through Composio
# BRAVE_SEARCH_API_KEY=

# Optional: dashboard/provider-admin hardening
# ENCRYPTION_KEY=change-me-long-random-secret
# DASHBOARD_USERNAME=kortny
# DASHBOARD_PASSWORD=change-me
# DASHBOARD_SESSION_SECRET=change-me-dashboard-session-secret
# DASHBOARD_HOST_PORT=8080

# Optional: LLM tier overrides
# LLM_CHEAP_MODEL=
# LLM_STANDARD_MODEL=
# LLM_ANALYSIS_MODEL=
# LLM_DOCUMENT_MODEL=
# LLM_HIGH_REASONING_MODEL=
# LLM_HUMANIZER_MODEL=

# Optional: runtime tuning
# AGENT_RUNTIME=adk
# KORTNY_WORKFLOW_BACKEND=inline
# KORTNY_PLANNED_WORKFLOWS_ENABLED=true
# KORTNY_PLANNED_WORKFLOW_COST_CEILING_USD=0.75

# Optional: semantic tool/skill retrieval (capability fabric)
# Local fastembed embeddings rank external tool cards and skills (pgvector).
# Set to "disabled" to fall back to pure lexical matching everywhere.
# KORTNY_EMBEDDINGS_BACKEND=local
# KORTNY_EMBEDDINGS_MODEL=BAAI/bge-small-en-v1.5
# KORTNY_TOOL_RETRIEVAL_TOP_K=15
# KORTNY_SKILL_DIRECT_THRESHOLD=0.60
# Where the worker caches downloaded embedding models (compose mounts the
# fastembed-cache volume here; first task downloads the model once).
# FASTEMBED_CACHE_PATH=/data/fastembed-cache

# Optional: sandbox runner for high-risk code/build execution
# Compose starts this by default. Set execution false to disable code execution.
# KORTNY_SANDBOX_RUNNER_URL=http://sandbox-runner:8090
# KORTNY_SANDBOX_RUNNER_TIMEOUT_SECONDS=70
# KORTNY_SANDBOX_DEFAULT_IMAGE=ghcr.io/astral-sh/uv:python3.11-bookworm-slim
# KORTNY_SANDBOX_EXECUTION_ENABLED=true

# Optional: sandbox workbench sessions (persistent per-task containers for
# sandbox_bash / sandbox_write_file / sandbox_read_file / exports / previews).
# Compose enables sessions by default; tune limits here.
# KORTNY_SANDBOX_SESSIONS_ENABLED=true
# KORTNY_SANDBOX_SESSION_CPUS=2.0
# KORTNY_SANDBOX_SESSION_MEMORY_MB=2048
# KORTNY_SANDBOX_SESSION_PIDS_LIMIT=512
# KORTNY_SANDBOX_SESSION_WORKSPACE_MB=1024
# KORTNY_SANDBOX_SESSION_IDLE_SECONDS=1800
# KORTNY_SANDBOX_SESSION_MAX_AGE_SECONDS=14400
# KORTNY_SANDBOX_SESSION_EXEC_MAX_TIMEOUT_SECONDS=300

# Sandbox preview links (sandbox_publish_preview). Set BOTH for preview links:
# the public URL where the dashboard is reachable and a long random secret
# used to sign capability URLs. Artifacts dir is shared between worker and
# dashboard (compose mounts the task-artifacts volume at /data/artifacts).
# KORTNY_PUBLIC_BASE_URL=https://kortny.example.com:8080
# KORTNY_PREVIEW_SIGNING_SECRET=change-me-long-random-string
# KORTNY_ARTIFACTS_DIR=/data/artifacts

# Optional: trusted-host static site deploys (deploy_site tool).
# Tokens stay on the worker; they are never injected into the sandbox.
# NETLIFY_AUTH_TOKEN=
# VERCEL_TOKEN=
# VERCEL_TEAM_ID=

# Optional: Scheduler and Witness tuning
# The Compose stack starts both by default. Witness creates candidates and
# autoreviews bounded, low-risk read-only proactive tasks unless disabled.
# KORTNY_SCHEDULER_POLL_INTERVAL_SECONDS=5
# KORTNY_WITNESS_ENABLED=true
# KORTNY_WITNESS_AUTOPILOT_ENABLED=true
# KORTNY_WITNESS_AUTOPILOT_LIMIT=1
# KORTNY_WITNESS_AUTOPILOT_MIN_CONFIDENCE=0.600
# KORTNY_WITNESS_DELIVER_PRIVATE=false
# KORTNY_WITNESS_POLL_INTERVAL_SECONDS=300
# KORTNY_WITNESS_AUTOMATION_ENABLED=true
# Proactivity quality loop (HIG-227): suggestions ship as one batched DM
# digest per user, gated by effective_confidence x receptivity.
# KORTNY_WITNESS_DELIVERY_THRESHOLD=0.55
# KORTNY_WITNESS_DIGEST_INTERVAL_HOURS=24
# KORTNY_WITNESS_DIGEST_MAX_ITEMS=5
# Quiet hours (UTC, 0-23): digests are deferred, never dropped. Unset = off.
# KORTNY_WITNESS_QUIET_HOURS_START=
# KORTNY_WITNESS_QUIET_HOURS_END=
# Deprecated: per-tick drip limit, retired in favor of the digest budget.
# KORTNY_WITNESS_DELIVERY_LIMIT=5

# Optional: Memory consolidator (HIG-225)
# Sleep-time memory brain: promotes task episodes into graph knowledge,
# adjudicates stuck candidates, merges duplicates, ages stale rows, reconciles
# confirmed facts, and runs retention hygiene. Runs when >=MIN_NEW_ITEMS new
# memory items accumulated AND >=MIN_INTERVAL_HOURS since the last run AND the
# workspace was quiet for QUIET_MINUTES — with a NIGHTLY_FLOOR_HOURS fallback.
# KORTNY_CONSOLIDATOR_ENABLED=true
# KORTNY_CONSOLIDATOR_POLL_INTERVAL_SECONDS=600
# KORTNY_CONSOLIDATOR_MIN_NEW_ITEMS=50
# KORTNY_CONSOLIDATOR_MIN_INTERVAL_HOURS=8
# KORTNY_CONSOLIDATOR_QUIET_MINUTES=60
# KORTNY_CONSOLIDATOR_NIGHTLY_FLOOR_HOURS=24
# KORTNY_CONSOLIDATOR_ADVISORY_LOCK_KEY=759340187
# Recency half-life for memory retrieval ranking; stale-aging window for graph
# rows without an explicit freshness window.
# KORTNY_MEMORY_RECENCY_HALF_LIFE_DAYS=14
# KORTNY_KG_STALE_DAYS=45
# Channel style cards (HIG-226): the consolidator learns each channel's
# register (formality, brevity, emoji norms) from observed activity and the
# humanizer/ack generator match it. Off => today's static style profile.
# KORTNY_STYLE_CARDS_ENABLED=true
# KORTNY_STYLE_CARD_MIN_MESSAGES=30

# Optional: local ports and database credentials
# Compose injects POSTGRES_URL into containers automatically.
# POSTGRES_HOST_PORT=5432
# POSTGRES_DB=kortny
# POSTGRES_USER=kortny
# POSTGRES_PASSWORD=kortny
# POSTGRES_URL=postgresql://kortny:kortny@localhost:5432/kortny

# Optional: OTEL/Phoenix/Langfuse observability
# OBSERVABILITY_ENABLED=true
# Prompt/response capture in traces + task timeline: metadata | summaries | full
# OBSERVABILITY_CAPTURE_CONTENT=summaries
# OTEL_EXPORTER_OTLP_ENDPOINT=
# OTEL_EXPORTER_OTLP_HEADERS=
# LANGFUSE_ENABLED=false
# LANGFUSE_HOST=
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=

# Optional: local Phoenix profile
# PHOENIX_IMAGE=arizephoenix/phoenix:latest
# PHOENIX_HOST_PORT=6006
# PHOENIX_SQL_DATABASE_URL=

# Optional: local Temporal profile
# Start with: docker compose --profile temporal up -d --force-recreate
# TEMPORAL_HOST_PORT=7233
# TEMPORAL_UI_HOST_PORT=8233
