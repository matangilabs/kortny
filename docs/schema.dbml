    `((onboarding_status)::text = ANY ((ARRAY['pending'::character varying, 'posted'::character varying, 'skipped'::character varying])::text[]))` [name: 'ck_slack_channel_memberships_onboarding_status']
    `((membership_status)::text = ANY ((ARRAY['active'::character varying, 'left'::character varying, 'unknown'::character varying])::text[]))` [name: 'ck_slack_channel_memberships_status']
