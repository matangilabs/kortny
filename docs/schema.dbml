  "path" "character varying" [not null]
  "kind" "character varying" [not null]
  "content_text" text
  "content_bytes" bytea
  "size_bytes" integer [not null]
  "sha256" "character varying" [not null]
  "created_at" timestamp [not null, default: `now()`]

  Checks {
    `((kind)::text = ANY ((ARRAY['reference'::character varying, 'asset'::character varying, 'script'::character varying])::text[]))` [name: 'ck_skill_files_kind']
  }

  Indexes {
    (skill_version_id, path) [unique, name: "uq_skill_files_version_path"]
    (skill_version_id, kind) [type: btree, name: "idx_skill_files_version"]
  }
}

Table "slack_channel_memberships" {
