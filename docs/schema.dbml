    `((((transport)::text = 'stdio'::text) AND (command IS NOT NULL)) OR (((transport)::text = ANY ((ARRAY['streamable_http'::character varying, 'sse'::character varying])::text[])) AND (url IS NOT NULL)))` [name: 'ck_mcp_servers_transport_target']
    `((trust_tier)::text = ANY ((ARRAY['trusted'::character varying, 'community'::character varying, 'untrusted'::character varying])::text[]))` [name: 'ck_mcp_servers_trust_tier']
