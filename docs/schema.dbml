Project kortny {
  database_type: 'PostgreSQL'
  Note: '''
  Kortny database schema — generated reference snapshot.

  This file is a snapshot of the live Postgres schema, generated from the
  database at Alembic migration `0041`. It is NOT hand-maintained and NOT the
  source of truth: the SQLAlchemy models (`kortny/db/models.py`) and the Alembic
  migrations (`kortny/db/migrations/versions/`) are. Change the schema there,
  then refresh this snapshot:

    docker compose exec -T postgres pg_dump -U kortny -d kortny --schema-only --no-owner --no-privileges -T alembic_version > schema.sql
    npx -y -p @dbml/cli sql2dbml --postgres schema.sql -o docs/schema.dbml
    (then restore this Project header at the top)

  Paste into https://dbdiagram.io to visualize. 44 tables spanning: tasks &
  the Postgres work queue, append-only task events, LLM usage & cost accounting,
  memory (workspace_state + episodes), the knowledge graph (entities / edges /
  evidence), observation, witness, scheduling, skills (procedural skills +
  files + enablements), MCP & Composio integration planes, dashboard auth, and
  Slack surfaces.
  '''
}

Enum "llm_provider" {
  "openai"
  "anthropic"
  "openrouter"
}

Enum "task_event_type" {
  "task_created"
  "status_changed"
  "llm_call"
  "tool_call"
  "tool_result"
  "artifact_created"
  "message_posted"
  "error"
  "log"
}

Enum "task_status" {
  "pending"
  "running"
  "succeeded"
  "failed"
  "crashed"
  "cancelled"
  "waiting_approval"
}

Table "artifacts" {
  "id" uuid [pk, not null, default: `gen_random_uuid()`]
  "task_id" uuid [not null]
  "filename" "character varying" [not null]
  "mime_type" "character varying"
  "size_bytes" bigint
  "storage_path" "character varying"
  "slack_file_id" "character varying"
  "posted_at" timestamp
  "created_at" timestamp [not null, default: `now()`]

  Indexes {
    task_id [type: btree, name: "idx_artifacts_task"]
  }
}

Table "assistant_thread_context" {
  "id" uuid [pk, not null, default: `gen_random_uuid()`]
  "channel_id" "character varying" [not null]
  "thread_ts" "character varying" [not null]
  "context_json" jsonb [not null, default: `'{}'::jsonb`]
  "created_at" timestamp [not null, default: `now()`]
  "updated_at" timestamp [not null, default: `now()`]

  Indexes {
    (channel_id, thread_ts) [unique, name: "uq_assistant_thread_context_channel_thread"]
  }
}

Table "autonomy_policies" {
  "id" uuid [pk, not null, default: `gen_random_uuid()`]
  "installation_id" uuid [not null]
  "scope_type" "character varying" [not null]
  "scope_id" "character varying"
  "level" "character varying" [not null]
  "updated_by_user_id" "character varying"
  "created_at" timestamp [not null, default: `now()`]
  "updated_at" timestamp [not null, default: `now()`]

  Checks {
    `((level)::text = ANY ((ARRAY['conservative'::character varying, 'balanced'::character varying, 'autonomous'::character varying])::text[]))` [name: 'ck_autonomy_policies_level']
    `((((scope_type)::text = 'workspace'::text) AND (scope_id IS NULL)) OR (((scope_type)::text = 'channel'::text) AND (scope_id IS NOT NULL)))` [name: 'ck_autonomy_policies_scope_id']
    `((scope_type)::text = ANY ((ARRAY['workspace'::character varying, 'channel'::character varying])::text[]))` [name: 'ck_autonomy_policies_scope_type']
  }

  Indexes {
    (installation_id, scope_type, scope_id) [type: btree, name: "idx_autonomy_policies_lookup"]
    (installation_id, scope_type, `COALESCE(scope_id,''::charactervarying)`) [type: btree, unique, name: "idx_autonomy_policies_scope_unique"]
  }
}

Table "composio_connections" {
  "id" uuid [pk, not null, default: `gen_random_uuid()`]
  "installation_id" uuid [not null]
  "toolkit_slug" "character varying" [not null]
  "auth_config_id" "character varying"
  "connected_account_id" "character varying"
  "connection_request_id" "character varying"
  "composio_user_id" "character varying" [not null]
  "owner_slack_user_id" "character varying" [not null]
  "visibility_scope_type" "character varying" [not null]
  "visibility_scope_id" "character varying"
  "status" "character varying" [not null]
  "display_name" "character varying"
  "external_account_label" "character varying"
  "metadata_json" jsonb [not null, default: `'{}'::jsonb`]
  "created_at" timestamp [not null, default: `now()`]
  "updated_at" timestamp [not null, default: `now()`]

  Checks {
    `((status)::text = ANY ((ARRAY['pending'::character varying, 'active'::character varying, 'expired'::character varying, 'failed'::character varying, 'disabled'::character varying])::text[]))` [name: 'ck_composio_connections_status']
    `((((visibility_scope_type)::text = 'workspace'::text) AND (visibility_scope_id IS NULL)) OR (((visibility_scope_type)::text = ANY ((ARRAY['channel'::character varying, 'user'::character varying])::text[])) AND (visibility_scope_id IS NOT NULL)))` [name: 'ck_composio_connections_visibility_scope_id']
    `((visibility_scope_type)::text = ANY ((ARRAY['workspace'::character varying, 'channel'::character varying, 'user'::character varying])::text[]))` [name: 'ck_composio_connections_visibility_scope_type']
  }

  Indexes {
    (installation_id, status, visibility_scope_type, visibility_scope_id) [type: btree, name: "idx_composio_connections_allowed_lookup"]
    (installation_id, connected_account_id) [type: btree, unique, name: "idx_composio_connections_connected_account"]
    (installation_id, owner_slack_user_id) [type: btree, name: "idx_composio_connections_owner"]
    (installation_id, toolkit_slug, status) [type: btree, name: "idx_composio_connections_toolkit"]
  }
}

Table "composio_tool_cards" {
  "id" uuid [pk, not null, default: `gen_random_uuid()`]
  "installation_id" uuid [not null]
  "toolkit_slug" "character varying" [not null]
  "tool_slug" "character varying" [not null]
  "name" "character varying" [not null]
  "description" text [not null]
  "side_effect" "character varying" [not null]
  "card_sha" "character varying(64)" [not null]
  "synced_at" timestamp [not null, default: `now()`]
  "created_at" timestamp [not null, default: `now()`]
  "updated_at" timestamp [not null, default: `now()`]

  Checks {
    `((side_effect)::text = ANY ((ARRAY['read'::character varying, 'write'::character varying, 'destructive'::character varying])::text[]))` [name: 'ck_composio_tool_cards_side_effect']
  }

  Indexes {
    (installation_id, tool_slug) [unique, name: "uq_composio_tool_cards_installation_tool"]
    (installation_id, toolkit_slug) [type: btree, name: "idx_composio_tool_cards_toolkit"]
  }
}

Table "consolidation_runs" {
  "id" uuid [pk, not null, default: `gen_random_uuid()`]
  "installation_id" uuid [not null]
  "started_at" timestamp [not null, default: `now()`]
  "finished_at" timestamp
  "status" text [not null, default: `'running'::text`]
  "counters_json" jsonb [not null, default: `'{}'::jsonb`]
  "cost_usd" numeric(12,6)
  "error" text

  Checks {
    `(status = ANY (ARRAY['running'::text, 'succeeded'::text, 'failed'::text]))` [name: 'ck_consolidation_runs_status']
  }

  Indexes {
    (installation_id, started_at) [type: btree, name: "idx_consolidation_runs_installation_started"]
  }
}

Table "dashboard_oauth_states" {
  "id" uuid [pk, not null, default: `gen_random_uuid()`]
  "provider" "character varying" [not null]
  "state" "character varying" [unique, not null]
  "redirect_path" "character varying" [not null]
  "created_at" timestamp [not null, default: `now()`]
  "expires_at" timestamp [not null]
  "used_at" timestamp

  Checks {
    `((provider)::text = 'slack'::text)` [name: 'ck_dashboard_oauth_states_provider']
  }

  Indexes {
    (provider, state, expires_at) [type: btree, name: "idx_dashboard_oauth_states_lookup"]
  }
}

Table "dashboard_users" {
  "id" uuid [pk, not null, default: `gen_random_uuid()`]
  "installation_id" uuid [not null]
  "slack_user_id" "character varying" [not null]
  "email" "character varying"
  "display_name" "character varying" [not null]
  "avatar_url" "character varying"
  "role" "character varying" [not null]
  "status" "character varying" [not null]
  "last_login_at" timestamp
  "created_at" timestamp [not null, default: `now()`]
  "updated_at" timestamp [not null, default: `now()`]

  Checks {
    `((role)::text = ANY ((ARRAY['admin'::character varying, 'member'::character varying])::text[]))` [name: 'ck_dashboard_users_role']
    `((status)::text = ANY ((ARRAY['active'::character varying, 'disabled'::character varying])::text[]))` [name: 'ck_dashboard_users_status']
  }

  Indexes {
    (installation_id, slack_user_id) [unique, name: "idx_dashboard_users_slack_user_unique"]
    (installation_id, email) [type: btree, unique, name: "idx_dashboard_users_email_unique"]
    (installation_id, role) [type: btree, name: "idx_dashboard_users_installation_role"]
    (installation_id, status) [type: btree, name: "idx_dashboard_users_status"]
  }
}

Table "encrypted_secrets" {
  "id" uuid [pk, not null, default: `gen_random_uuid()`]
  "installation_id" uuid [not null]
  "secret_type" "character varying" [not null]
  "ciphertext" bytea [not null]
  "created_at" timestamp [not null, default: `now()`]
  "updated_at" timestamp [not null, default: `now()`]

  Indexes {
    (installation_id, secret_type) [unique, name: "idx_secret_lookup"]
  }
}

Table "episodes" {
  "id" uuid [pk, not null, default: `gen_random_uuid()`]
  "installation_id" uuid [not null]
  "task_id" uuid [unique, not null]
  "channel_id" "character varying" [not null]
  "user_id" "character varying" [not null]
  "thread_ts" "character varying"
  "summary" text [not null]
  "tools_used" jsonb [not null, default: `'[]'::jsonb`]
  "artifacts_created" jsonb [not null, default: `'[]'::jsonb`]
  "source_refs" jsonb [not null, default: `'[]'::jsonb`]
  "outcome" "character varying" [not null]
  "error_json" jsonb
  "created_at" timestamp [not null, default: `now()`]
  "updated_at" timestamp [not null, default: `now()`]

  Checks {
    `((outcome)::text = ANY ((ARRAY['succeeded'::character varying, 'failed'::character varying, 'cancelled'::character varying])::text[]))` [name: 'ck_episodes_outcome']
  }

  Indexes {
    (installation_id, channel_id, created_at) [type: btree, name: "idx_episodes_channel"]
    (installation_id, channel_id, thread_ts) [type: btree, name: "idx_episodes_thread"]
    (installation_id, user_id, created_at) [type: btree, name: "idx_episodes_user"]
  }
}

Table "installations" {
  "id" uuid [pk, not null, default: `gen_random_uuid()`]
  "slack_team_id" "character varying" [unique, not null]
  "team_name" "character varying"
  "bot_user_id" "character varying"
  "created_at" timestamp [not null, default: `now()`]
  "updated_at" timestamp [not null, default: `now()`]
}

Table "kg_edges" {
  "id" uuid [pk, not null, default: `gen_random_uuid()`]
  "installation_id" uuid [not null]
  "source_entity_id" uuid [not null]
  "target_entity_id" uuid [not null]
  "relationship_type" "character varying" [not null]
  "attrs_json" jsonb [not null, default: `'{}'::jsonb`]
  "visibility_scope_type" "character varying" [not null]
  "visibility_scope_id" "character varying"
  "source_type" "character varying" [not null]
  "confidence_score" numeric(4,3) [not null, default: 0.500]
  "confidence_reason" text
  "lifecycle_state" "character varying" [not null, default: `'candidate'::charactervarying`]
  "valid_from" timestamp [not null, default: `now()`]
  "valid_to" timestamp
  "recorded_at" timestamp [not null, default: `now()`]
  "expired_at" timestamp
  "is_current" boolean [not null, default: true]
  "freshness_window_days" integer
  "last_reinforced_at" timestamp
  "reinforcement_count" integer [not null, default: 0]
  "created_at" timestamp [not null, default: `now()`]
  "updated_at" timestamp [not null, default: `now()`]
  "valid_at" timestamp
  "invalid_at" timestamp
  "system_expired_at" timestamp

  Checks {
    `((confidence_score >= (0)::numeric) AND (confidence_score <= (1)::numeric))` [name: 'ck_kg_edges_confidence_score']
    `((lifecycle_state)::text = ANY ((ARRAY['candidate'::character varying, 'active'::character varying, 'confirmed'::character varying, 'stale'::character varying, 'superseded'::character varying, 'contradicted'::character varying, 'archived'::character varying, 'forgotten'::character varying])::text[]))` [name: 'ck_kg_edges_lifecycle_state']
    `(reinforcement_count >= 0)` [name: 'ck_kg_edges_reinforcement_count']
    `((relationship_type)::text = ANY ((ARRAY['member_of'::character varying, 'maps_to'::character varying, 'works_on'::character varying, 'owns'::character varying, 'belongs_to'::character varying, 'referenced_in'::character varying, 'made_in'::character varying, 'affects'::character varying, 'relates_to'::character varying, 'available_for'::character varying])::text[]))` [name: 'ck_kg_edges_relationship_type']
    `((source_type)::text = ANY ((ARRAY['slack_authoritative'::character varying, 'user_explicit'::character varying, 'user_confirmed'::character varying, 'agent_inferred'::character varying, 'onboarding_scan'::character varying, 'task_summary'::character varying, 'integration_result'::character varying, 'workspace_state'::character varying, 'admin_import'::character varying])::text[]))` [name: 'ck_kg_edges_source_type']
    `((((visibility_scope_type)::text = 'workspace'::text) AND (visibility_scope_id IS NULL)) OR (((visibility_scope_type)::text = ANY ((ARRAY['channel'::character varying, 'private_channel'::character varying, 'dm'::character varying, 'user'::character varying])::text[])) AND (visibility_scope_id IS NOT NULL)))` [name: 'ck_kg_edges_visibility_scope_id']
    `((visibility_scope_type)::text = ANY ((ARRAY['workspace'::character varying, 'channel'::character varying, 'private_channel'::character varying, 'dm'::character varying, 'user'::character varying])::text[]))` [name: 'ck_kg_edges_visibility_scope_type']
  }

  Indexes {
    attrs_json [type: gin, name: "idx_kg_edges_attrs"]
    (installation_id, source_entity_id, target_entity_id, relationship_type, visibility_scope_type, `COALESCE(visibility_scope_id,''::charactervarying)`) [type: btree, unique, name: "idx_kg_edges_current_unique"]
    invalid_at [type: btree, name: "idx_kg_edges_invalid_at"]
    (installation_id, visibility_scope_type, visibility_scope_id) [type: btree, name: "idx_kg_edges_scope"]
    (installation_id, source_entity_id, relationship_type, is_current) [type: btree, name: "idx_kg_edges_source_lookup"]
    (installation_id, target_entity_id, relationship_type, is_current) [type: btree, name: "idx_kg_edges_target_lookup"]
  }
}

Table "kg_entities" {
  "id" uuid [pk, not null, default: `gen_random_uuid()`]
  "installation_id" uuid [not null]
  "entity_type" "character varying" [not null]
  "canonical_key" "character varying" [not null]
  "display_name" "character varying"
  "external_ref_type" "character varying"
  "external_ref_id" "character varying"
  "attrs_json" jsonb [not null, default: `'{}'::jsonb`]
  "visibility_scope_type" "character varying" [not null]
  "visibility_scope_id" "character varying"
  "source_type" "character varying" [not null]
  "confidence_score" numeric(4,3) [not null, default: 0.500]
  "confidence_reason" text
  "lifecycle_state" "character varying" [not null, default: `'candidate'::charactervarying`]
  "valid_from" timestamp [not null, default: `now()`]
  "valid_to" timestamp
  "recorded_at" timestamp [not null, default: `now()`]
  "expired_at" timestamp
  "is_current" boolean [not null, default: true]
  "freshness_window_days" integer
  "last_reinforced_at" timestamp
  "reinforcement_count" integer [not null, default: 0]
  "created_at" timestamp [not null, default: `now()`]
  "updated_at" timestamp [not null, default: `now()`]
  "valid_at" timestamp
  "invalid_at" timestamp
  "system_expired_at" timestamp

  Checks {
    `((confidence_score >= (0)::numeric) AND (confidence_score <= (1)::numeric))` [name: 'ck_kg_entities_confidence_score']
    `((lifecycle_state)::text = ANY ((ARRAY['candidate'::character varying, 'active'::character varying, 'confirmed'::character varying, 'stale'::character varying, 'superseded'::character varying, 'contradicted'::character varying, 'archived'::character varying, 'forgotten'::character varying])::text[]))` [name: 'ck_kg_entities_lifecycle_state']
    `(reinforcement_count >= 0)` [name: 'ck_kg_entities_reinforcement_count']
    `((source_type)::text = ANY ((ARRAY['slack_authoritative'::character varying, 'user_explicit'::character varying, 'user_confirmed'::character varying, 'agent_inferred'::character varying, 'onboarding_scan'::character varying, 'task_summary'::character varying, 'integration_result'::character varying, 'workspace_state'::character varying, 'admin_import'::character varying])::text[]))` [name: 'ck_kg_entities_source_type']
    `((entity_type)::text = ANY ((ARRAY['person'::character varying, 'channel'::character varying, 'project'::character varying, 'firm_fact'::character varying, 'artifact'::character varying, 'decision'::character varying, 'open_question'::character varying, 'commitment'::character varying, 'integration'::character varying, 'external_entity'::character varying])::text[]))` [name: 'ck_kg_entities_type']
    `((((visibility_scope_type)::text = 'workspace'::text) AND (visibility_scope_id IS NULL)) OR (((visibility_scope_type)::text = ANY ((ARRAY['channel'::character varying, 'private_channel'::character varying, 'dm'::character varying, 'user'::character varying])::text[])) AND (visibility_scope_id IS NOT NULL)))` [name: 'ck_kg_entities_visibility_scope_id']
    `((visibility_scope_type)::text = ANY ((ARRAY['workspace'::character varying, 'channel'::character varying, 'private_channel'::character varying, 'dm'::character varying, 'user'::character varying])::text[]))` [name: 'ck_kg_entities_visibility_scope_type']
  }

  Indexes {
    attrs_json [type: gin, name: "idx_kg_entities_attrs"]
    (installation_id, canonical_key) [type: btree, unique, name: "idx_kg_entities_current_unique_key"]
    (external_ref_type, external_ref_id) [type: btree, name: "idx_kg_entities_external_ref"]
    invalid_at [type: btree, name: "idx_kg_entities_invalid_at"]
    (installation_id, entity_type, lifecycle_state, is_current) [type: btree, name: "idx_kg_entities_lookup"]
    (installation_id, visibility_scope_type, visibility_scope_id) [type: btree, name: "idx_kg_entities_scope"]
  }
}

Table "kg_evidence" {
  "id" uuid [pk, not null, default: `gen_random_uuid()`]
  "installation_id" uuid [not null]
  "target_kind" "character varying" [not null]
  "target_id" uuid [not null]
  "source_type" "character varying" [not null]
  "source_task_id" uuid
  "source_episode_id" uuid
  "source_task_event_id" bigint
  "source_observation_id" uuid
  "source_slack_channel_id" "character varying"
  "source_slack_message_ts" "character varying"
  "source_slack_file_id" "character varying"
  "source_url" text
  "extracted_by" "character varying" [not null]
  "raw_snippet" text
  "confidence_score" numeric(4,3)
  "confidence_reason" text
  "consensus_count" integer [not null, default: 1]
  "created_at" timestamp [not null, default: `now()`]

  Checks {
    `((confidence_score IS NULL) OR ((confidence_score >= (0)::numeric) AND (confidence_score <= (1)::numeric)))` [name: 'ck_kg_evidence_confidence_score']
    `(consensus_count > 0)` [name: 'ck_kg_evidence_consensus_count']
    `(((source_type)::text = 'admin_import'::text) OR (source_task_id IS NOT NULL) OR (source_episode_id IS NOT NULL) OR (source_task_event_id IS NOT NULL) OR (source_observation_id IS NOT NULL) OR (source_slack_channel_id IS NOT NULL) OR (source_slack_file_id IS NOT NULL) OR (source_url IS NOT NULL))` [name: 'ck_kg_evidence_source_reference']
    `((source_type)::text = ANY ((ARRAY['slack_authoritative'::character varying, 'user_explicit'::character varying, 'agent_inferred'::character varying, 'onboarding_scan'::character varying, 'task_summary'::character varying, 'integration_result'::character varying, 'workspace_state'::character varying, 'admin_import'::character varying])::text[]))` [name: 'ck_kg_evidence_source_type']
    `((target_kind)::text = ANY ((ARRAY['entity'::character varying, 'edge'::character varying])::text[]))` [name: 'ck_kg_evidence_target_kind']
  }

  Indexes {
    source_episode_id [type: btree, name: "idx_kg_evidence_episode"]
    source_observation_id [type: btree, name: "idx_kg_evidence_observation"]
    (installation_id, source_slack_channel_id, source_slack_message_ts) [type: btree, name: "idx_kg_evidence_slack_message"]
    (target_kind, target_id) [type: btree, name: "idx_kg_evidence_target"]
    source_task_id [type: btree, name: "idx_kg_evidence_task"]
  }
}

Table "llm_budget_policies" {
  "id" uuid [pk, not null, default: `gen_random_uuid()`]
  "installation_id" uuid [not null]
  "tier" "character varying"
  "daily_budget_usd" numeric(12,2)
  "monthly_budget_usd" numeric(12,2)
  "alert_threshold_pct" integer [not null, default: 80]
  "behavior" "character varying" [not null, default: `'soft_stop'::charactervarying`]
  "is_active" boolean [not null, default: true]
  "metadata_json" jsonb [not null, default: `'{}'::jsonb`]
  "created_at" timestamp [not null, default: `now()`]
  "updated_at" timestamp [not null, default: `now()`]

  Checks {
    `((alert_threshold_pct >= 1) AND (alert_threshold_pct <= 100))` [name: 'ck_llm_budget_policies_alert_threshold']
    `((behavior)::text = ANY ((ARRAY['soft_stop'::character varying, 'hard_stop'::character varying])::text[]))` [name: 'ck_llm_budget_policies_behavior']
    `((tier IS NULL) OR ((tier)::text = ANY ((ARRAY['cheap_fast'::character varying, 'standard'::character varying, 'analysis'::character varying, 'document'::character varying, 'high_reasoning'::character varying, 'humanizer'::character varying])::text[])))` [name: 'ck_llm_budget_policies_tier']
  }

  Indexes {
    (installation_id, is_active) [type: btree, name: "idx_llm_budget_policies_installation"]
  }
}

Table "llm_config_audit" {
  "id" uuid [pk, not null, default: `gen_random_uuid()`]
  "installation_id" uuid [not null]
  "actor_slack_user_id" "character varying"
  "action" "character varying" [not null]
  "entity_type" "character varying" [not null]
  "entity_id" "character varying"
  "previous_value" jsonb
  "new_value" jsonb
  "created_at" timestamp [not null, default: `now()`]

  Checks {
    `((action)::text = ANY ((ARRAY['create'::character varying, 'update'::character varying, 'disable'::character varying, 'enable'::character varying, 'delete'::character varying, 'bootstrap'::character varying])::text[]))` [name: 'ck_llm_config_audit_action']
  }

  Indexes {
    (installation_id, created_at) [type: btree, name: "idx_llm_config_audit_installation"]
  }
}

Table "llm_model_catalog" {
  "id" uuid [pk, not null, default: `gen_random_uuid()`]
  "provider_account_id" uuid [not null]
  "model_identifier" "character varying" [not null]
