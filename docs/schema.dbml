    `((status)::text = ANY ((ARRAY['active'::character varying, 'drifted'::character varying])::text[]))` [name: 'ck_tool_pins_status']
  }

  Indexes {
    (installation_id, provider, server_ref, tool_name) [unique, name: "uq_tool_pins_identity"]
