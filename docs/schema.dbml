Table "tasks" {
  "id" uuid [pk, not null, default: `gen_random_uuid()`]
  "installation_id" uuid [not null]
  "parent_task_id" uuid
  "slack_event_id" "character varying" [unique]
  "slack_channel_id" "character varying" [not null]
  "slack_thread_ts" "character varying"
  "slack_message_ts" "character varying"
  "slack_user_id" "character varying" [not null]
  "input" text [not null]
  "status" task_status [not null, default: `'pending'::public.task_status`]
  "result_summary" text
  "error" jsonb
  "available_at" timestamp [not null, default: `now()`]
  "locked_by" "character varying"
  "locked_at" timestamp
  "lease_expires_at" timestamp
  "attempts" integer [not null, default: 0]
  "max_attempts" integer [not null, default: 3]
  "total_input_tokens" integer [not null, default: 0]
  "total_output_tokens" integer [not null, default: 0]
  "total_cost_usd" numeric(12,6) [not null, default: 0]
  "created_at" timestamp [not null, default: `now()`]
  "started_at" timestamp
  "finished_at" timestamp
  "updated_at" timestamp [not null, default: `now()`]
  "identity_kind" "character varying"
  "identity_key" "character varying"
  "identity_payload" jsonb [not null, default: `'{}'::jsonb`]
  "identity_fingerprint" "character varying"

  Checks {
    `((identity_kind IS NULL) OR ((identity_kind)::text = ANY ((ARRAY['slack_message'::character varying, 'slack_event'::character varying, 'synthetic'::character varying, 'scheduled'::character varying, 'manual'::character varying])::text[])))` [name: 'ck_tasks_identity_kind']
  }

  Indexes {
    (status, available_at) [type: btree, name: "idx_tasks_claim"]
    (installation_id, created_at) [type: btree, name: "idx_tasks_history"]
    (installation_id, identity_key) [type: btree, unique, name: "idx_tasks_identity_unique"]
    (slack_channel_id, slack_thread_ts) [type: btree, name: "idx_tasks_thread"]
  }
}

