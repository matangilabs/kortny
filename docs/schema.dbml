  "candidate_id" uuid
  "decision" text [not null]
  "reason" text
  "created_at" timestamp [not null, default: `now()`]

  Checks {
    `(decision = ANY (ARRAY['notify'::text, 'question'::text, 'draft'::text, 'silent'::text, 'digest'::text, 'channel_sent'::text, 'channel_deferred'::text, 'draft_executed'::text, 'ambient_file_brief'::text]))` [name: 'ck_witness_delivery_log_decision']
  }

  Indexes {
    candidate_id [type: btree, name: "idx_witness_delivery_log_candidate"]
    (installation_id, decision, created_at) [type: btree, name: "idx_witness_delivery_log_decision"]
    (installation_id, slack_user_id, created_at) [type: btree, name: "idx_witness_delivery_log_user_window"]
  }
}

Table "witness_opportunity_candidates" {
  "id" uuid [pk, not null, default: `gen_random_uuid()`]
  "installation_id" uuid [not null]
  "channel_id" "character varying"
  "target_slack_user_id" "character varying"
  "visibility_scope_type" "character varying" [not null]
  "visibility_scope_id" "character varying"
  "candidate_type" "character varying" [not null]
  "title" "character varying" [not null]
  "summary" text [not null]
  "suggested_action" text
  "suggested_message" text
  "evidence_json" jsonb [not null, default: `'[]'::jsonb`]
  "source_type" "character varying" [not null]
  "source_id" "character varying"
  "source_task_id" uuid
  "source_profile_id" uuid
  "dedupe_key" "character varying" [not null]
  "confidence_score" numeric(4,3) [not null, default: 0.500]
  "confidence_reason" text
  "status" "character varying" [not null, default: `'candidate'::charactervarying`]
  "cooldown_until" timestamp
  "last_suggested_at" timestamp
  "feedback_json" jsonb [not null, default: `'{}'::jsonb`]
  "metadata_json" jsonb [not null, default: `'{}'::jsonb`]
  "created_at" timestamp [not null, default: `now()`]
  "updated_at" timestamp [not null, default: `now()`]
  "automation_kind" text
  "cadence_suggestion" text
  "deliverable" text
  "automated_schedule_id" uuid
  "automated_task_id" uuid
  "reinforcement_count" integer [not null, default: 1]
  "first_observed_at" timestamp
  "last_decision" text
  "receptivity_score" numeric(4,3)

  Checks {
    `((automation_kind IS NULL) OR (automation_kind = ANY (ARRAY['recurring'::text, 'one_shot'::text, 'watch'::text])))` [name: 'ck_witness_opportunity_candidates_automation_kind']
    `((confidence_score >= (0)::numeric) AND (confidence_score <= (1)::numeric))` [name: 'ck_witness_opportunity_candidates_confidence']
    `((last_decision IS NULL) OR (last_decision = ANY (ARRAY['notify'::text, 'question'::text, 'draft'::text, 'silent'::text])))` [name: 'ck_witness_opportunity_candidates_last_decision']
    `((receptivity_score IS NULL) OR ((receptivity_score >= (0)::numeric) AND (receptivity_score <= (1)::numeric)))` [name: 'ck_witness_opportunity_candidates_receptivity']
    `(reinforcement_count >= 0)` [name: 'ck_witness_opportunity_candidates_reinforcement_count']
    `((((visibility_scope_type)::text = 'workspace'::text) AND (visibility_scope_id IS NULL)) OR (((visibility_scope_type)::text = ANY ((ARRAY['channel'::character varying, 'private_channel'::character varying, 'dm'::character varying, 'user'::character varying])::text[])) AND (visibility_scope_id IS NOT NULL)))` [name: 'ck_witness_opportunity_candidates_scope_id']
    `((visibility_scope_type)::text = ANY ((ARRAY['workspace'::character varying, 'channel'::character varying, 'private_channel'::character varying, 'dm'::character varying, 'user'::character varying])::text[]))` [name: 'ck_witness_opportunity_candidates_scope_type']
    `((source_type)::text = ANY ((ARRAY['channel_profile'::character varying, 'knowledge_graph'::character varying, 'task_summary'::character varying, 'scheduled_witness'::character varying, 'manual'::character varying])::text[]))` [name: 'ck_witness_opportunity_candidates_source_type']
    `((status)::text = ANY ((ARRAY['candidate'::character varying, 'sent'::character varying, 'accepted'::character varying, 'automated'::character varying, 'dismissed'::character varying, 'cooldown'::character varying, 'superseded'::character varying, 'archived'::character varying])::text[]))` [name: 'ck_witness_opportunity_candidates_status']
    `((candidate_type)::text = ANY ((ARRAY['workflow_gap'::character varying, 'artifact_followup'::character varying, 'unresolved_decision'::character varying, 'data_quality_issue'::character varying, 'recurring_check'::character varying, 'project_status_gap'::character varying, 'general_help'::character varying])::text[]))` [name: 'ck_witness_opportunity_candidates_type']
  }

  Indexes {
    (installation_id, channel_id, status) [type: btree, name: "idx_witness_opportunity_candidates_channel"]
    evidence_json [type: gin, name: "idx_witness_opportunity_candidates_evidence"]
    source_profile_id [type: btree, name: "idx_witness_opportunity_candidates_profile"]
    (installation_id, visibility_scope_type, visibility_scope_id) [type: btree, name: "idx_witness_opportunity_candidates_scope"]
    (installation_id, status, cooldown_until) [type: btree, name: "idx_witness_opportunity_candidates_status"]
    source_task_id [type: btree, name: "idx_witness_opportunity_candidates_task"]
    (installation_id, visibility_scope_type, `COALESCE(visibility_scope_id,''::charactervarying)`, candidate_type, dedupe_key) [type: btree, unique, name: "idx_witness_opportunity_candidates_unique"]
  }
}

Table "workspace_state" {
  "id" uuid [pk, not null, default: `gen_random_uuid()`]
  "installation_id" uuid [not null]
  "scope_type" "character varying" [not null]
  "scope_id" "character varying"
  "key" "character varying" [not null]
  "value_json" jsonb [not null]
  "value_text" text
  "status" "character varying" [not null]
  "source_kind" "character varying" [not null]
  "source_task_id" uuid
  "source_event_id" bigint
  "source_slack_channel_id" "character varying"
  "source_slack_message_ts" "character varying"
  "source_slack_file_id" "character varying"
  "source_url" text
  "proposed_by" "character varying" [not null]
  "proposed_reason" text
  "confidence_score" numeric(4,3)
  "confidence_reason" text
  "confirmed_by_user_id" "character varying"
  "confirmed_at" timestamp
  "rejected_by_user_id" "character varying"
  "rejected_at" timestamp
  "superseded_by_id" uuid
  "superseded_at" timestamp
  "forgotten_by_user_id" "character varying"
  "forgotten_at" timestamp
  "expires_at" timestamp
  "created_at" timestamp [not null, default: `now()`]
  "updated_at" timestamp [not null, default: `now()`]

  Checks {
    `((((scope_type)::text = 'workspace'::text) AND (scope_id IS NULL)) OR (((scope_type)::text = ANY ((ARRAY['channel'::character varying, 'user'::character varying])::text[])) AND (scope_id IS NOT NULL)))` [name: 'ck_workspace_state_scope_id']
    `((scope_type)::text = ANY ((ARRAY['workspace'::character varying, 'channel'::character varying, 'user'::character varying])::text[]))` [name: 'ck_workspace_state_scope_type']
    `((source_kind)::text = ANY ((ARRAY['user_explicit'::character varying, 'agent_proposed'::character varying, 'summarizer_proposed'::character varying, 'observer_proposed'::character varying, 'import'::character varying])::text[]))` [name: 'ck_workspace_state_source_kind']
    `((status)::text = ANY ((ARRAY['proposed'::character varying, 'active'::character varying, 'rejected'::character varying, 'superseded'::character varying, 'forgotten'::character varying])::text[]))` [name: 'ck_workspace_state_status']
  }

  Indexes {
    (installation_id, status, scope_type, scope_id) [type: btree, name: "idx_workspace_state_active_lookup"]
    (installation_id, scope_type, `COALESCE(scope_id,''::charactervarying)`, key) [type: btree, unique, name: "idx_workspace_state_active_unique"]
    expires_at [type: btree, name: "idx_workspace_state_expires_at"]
    (source_task_id, source_event_id) [type: btree, name: "idx_workspace_state_source"]
  }
}

