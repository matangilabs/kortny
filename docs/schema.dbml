  "operation" "character varying" [not null]
  "purpose" "character varying"
  "target_channel_id" "character varying"
  "target_thread_ts" "character varying"
  "target_message_ts" "character varying"
  "request_json" jsonb [not null, default: `'{}'::jsonb`]
  "response_json" jsonb
  "status" "character varying" [not null, default: `'pending'::charactervarying`]
  "attempts" integer [not null, default: 0]
  "last_error" jsonb
  "available_at" timestamp [not null, default: `now()`]
  "started_at" timestamp
  "delivered_at" timestamp
  "created_at" timestamp [not null, default: `now()`]
  "updated_at" timestamp [not null, default: `now()`]

  Checks {
    `((operation)::text = ANY ((ARRAY['chat_postMessage'::character varying, 'files_upload_v2'::character varying, 'reactions_add'::character varying, 'reactions_remove'::character varying, 'pins_add'::character varying, 'bookmarks_add'::character varying, 'conversations_canvases_create'::character varying, 'canvases_edit'::character varying])::text[]))` [name: 'ck_slack_side_effects_operation']
    `((status)::text = ANY ((ARRAY['pending'::character varying, 'in_progress'::character varying, 'succeeded'::character varying, 'failed'::character varying])::text[]))` [name: 'ck_slack_side_effects_status']
  }

  Indexes {
    (installation_id, idempotency_key) [unique, name: "idx_slack_side_effects_idempotency"]
    (installation_id, status, available_at) [type: btree, name: "idx_slack_side_effects_status"]
    (installation_id, target_channel_id, target_message_ts) [type: btree, name: "idx_slack_side_effects_target"]
    (task_id, created_at) [type: btree, name: "idx_slack_side_effects_task"]
  }
}

