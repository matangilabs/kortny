  Checks {
    `((((owner_type)::text = 'system'::text) AND (owner_id IS NULL)) OR (((owner_type)::text = ANY ((ARRAY['workspace'::character varying, 'user'::character varying])::text[])) AND (owner_id IS NOT NULL)))` [name: 'ck_procedural_skills_owner_id']
    `((owner_type)::text = ANY ((ARRAY['system'::character varying, 'workspace'::character varying, 'user'::character varying])::text[]))` [name: 'ck_procedural_skills_owner_type']
    `((status)::text = ANY ((ARRAY['draft'::character varying, 'active'::character varying, 'deprecated'::character varying, 'disabled'::character varying, 'archived'::character varying])::text[]))` [name: 'ck_procedural_skills_status']
    `((trust_level)::text = ANY ((ARRAY['trusted'::character varying, 'community'::character varying, 'untrusted'::character varying, 'quarantined'::character varying])::text[]))` [name: 'ck_procedural_skills_trust_level']
    `((visibility)::text = ANY ((ARRAY['catalog'::character varying, 'explicit_only'::character varying, 'disabled'::character varying])::text[]))` [name: 'ck_procedural_skills_visibility']
  }

  Indexes {
    (owner_type, status, visibility, slug) [type: btree, name: "idx_procedural_skills_catalog"]
    (owner_type, `COALESCE(owner_id,''::charactervarying)`, slug) [type: btree, unique, name: "idx_procedural_skills_unique_slug"]
  }
}

Table "schedules" {
  "id" uuid [pk, not null, default: `gen_random_uuid()`]
  "installation_id" uuid [not null]
  "owner_type" "character varying" [not null]
  "owner_slack_user_id" "character varying"
  "title" "character varying" [not null]
  "spec_kind" "character varying" [not null]
  "cron_expr" "character varying"
  "interval_seconds" integer
  "run_at" timestamp
  "timezone" "character varying" [not null, default: `'UTC'::charactervarying`]
  "next_run_at" timestamp
  "last_run_at" timestamp
  "catchup_policy" "character varying" [not null, default: `'skip'::charactervarying`]
  "catchup_window_seconds" integer
  "overlap_policy" "character varying" [not null, default: `'skip'::charactervarying`]
  "status" "character varying" [not null, default: `'active'::charactervarying`]
  "task_template" jsonb [not null, default: `'{}'::jsonb`]
  "planned_cost_ceiling_usd" numeric(10,4)
  "idempotency_key_template" "character varying"
  "created_by_slack_user_id" "character varying"
  "metadata_json" jsonb [not null, default: `'{}'::jsonb`]
  "created_at" timestamp [not null, default: `now()`]
  "updated_at" timestamp [not null, default: `now()`]
  "delivery_kind" "character varying" [not null, default: `'slack_dm'::charactervarying`]
  "delivery_slack_user_id" "character varying"
  "delivery_slack_channel_id" "character varying"
  "delivery_slack_thread_ts" "character varying"
  "artifact_delivery_policy" "character varying" [not null, default: `'message_only'::charactervarying`]

  Checks {
    `((artifact_delivery_policy)::text = ANY ((ARRAY['message_only'::character varying, 'attach_files'::character varying, 'link_artifacts'::character varying])::text[]))` [name: 'ck_schedules_artifact_delivery_policy']
    `((catchup_policy)::text = ANY ((ARRAY['skip'::character varying, 'run_once'::character varying, 'backfill'::character varying])::text[]))` [name: 'ck_schedules_catchup_policy']
    `((catchup_window_seconds IS NULL) OR (catchup_window_seconds >= 0))` [name: 'ck_schedules_catchup_window']
    `((planned_cost_ceiling_usd IS NULL) OR (planned_cost_ceiling_usd > (0)::numeric))` [name: 'ck_schedules_cost_ceiling']
    `((delivery_kind)::text = ANY ((ARRAY['slack_dm'::character varying, 'slack_channel'::character varying, 'slack_thread'::character varying, 'dashboard_only'::character varying])::text[]))` [name: 'ck_schedules_delivery_kind']
    `((overlap_policy)::text = ANY ((ARRAY['skip'::character varying, 'allow'::character varying])::text[]))` [name: 'ck_schedules_overlap_policy']
    `((((owner_type)::text = 'user'::text) AND (owner_slack_user_id IS NOT NULL)) OR ((owner_type)::text = 'system'::text))` [name: 'ck_schedules_owner']
    `((owner_type)::text = ANY ((ARRAY['user'::character varying, 'system'::character varying])::text[]))` [name: 'ck_schedules_owner_type']
    `((((spec_kind)::text = 'oneoff'::text) AND (run_at IS NOT NULL)) OR (((spec_kind)::text = 'interval'::text) AND (interval_seconds IS NOT NULL) AND (interval_seconds > 0)) OR (((spec_kind)::text = 'cron'::text) AND (cron_expr IS NOT NULL) AND ((cron_expr)::text <> ''::text)))` [name: 'ck_schedules_spec']
    `((spec_kind)::text = ANY ((ARRAY['oneoff'::character varying, 'interval'::character varying, 'cron'::character varying])::text[]))` [name: 'ck_schedules_spec_kind']
    `((status)::text = ANY ((ARRAY['proposed'::character varying, 'active'::character varying, 'paused'::character varying, 'completed'::character varying, 'cancelled'::character varying])::text[]))` [name: 'ck_schedules_status']
  }

  Indexes {
    next_run_at [type: btree, name: "idx_schedules_due"]
    (installation_id, owner_type, owner_slack_user_id, status) [type: btree, name: "idx_schedules_owner"]
    (installation_id, status, next_run_at) [type: btree, name: "idx_schedules_status"]
  }
}

